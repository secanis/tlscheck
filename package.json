{
  "name": "tlscheck",
  "version": "0.1.0",
  "description": "TLS/SSL Certificate Checker - Chrome/Browser Extension + API",
  "license": "AGPL-3.0",
  "repository": "github:secanis/tlscheck",
  "author": "matthias.baldi@secanis.ch",
  "homepage": "https://tlscheck.net",
  "bugs": "https://github.com/secanis/tlscheck/issues",
  "keywords": [
    "ssl",
    "tls",
    "certificate",
    "chrome-extension",
    "browser-extension",
    "security",
    "revocation",
    "javascript",
    "typescript",
    "nodejs"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:api": "tsc -p tsconfig.json",
    "build:chrome": "node scripts/build.js chrome",
    "build:extension": "tsc -p tsconfig.extension.json",
    "generate:openapi": "node scripts/generate-openapi.js",
    "prebuild:docs": "npm run generate:openapi",
    "build:docs": "cd docs && npm run build",
    "dev": "tsx --env-file=.env.development --watch api/index.ts",
    "start:api": "node dist/api/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.7.4",
    "fastify-metrics": "^12.1.0",
    "node-forge": "^1.3.3",
    "ocsp": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
